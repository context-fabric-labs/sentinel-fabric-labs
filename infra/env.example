# AWS Infrastructure Environment Variables

# AWS Region where the cluster will be created
AWS_REGION=us-east-1

# Unique cluster name
CLUSTER_NAME=sentinel-fabric-platform-cell

# AWS Account ID (automatically detected if not set)
# ACCOUNT_ID=123456789012

# S3 Bucket for cluster state management
S3_BUCKET=sentinel-fabric-cluster-state

# VPC CIDR block
VPC_CIDR=10.0.0.0/16

# Platform Cell Node Group Configuration
PLATFORM_CELL_NODE_TYPE=c5.large
PLATFORM_CELL_MIN_NODES=2
PLATFORM_CELL_MAX_NODES=10
PLATFORM_CELL_DESIRED_NODES=2

# GPU Cell Node Group Configuration
GPU_CELL_NODE_TYPE=p3.2xlarge
GPU_CELL_MIN_NODES=0
GPU_CELL_MAX_NODES=5
GPU_CELL_DESIRED_NODES=0

# EFA Cell Node Group Configuration
EFA_CELL_NODE_TYPE=c5n.18xlarge
EFA_CELL_MIN_NODES=0
EFA_CELL_MAX_NODES=3
EFA_CELL_DESIRED_NODES=0